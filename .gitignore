# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.python-version

# Model weights and cache (HUGE files)
*.bin
*.safetensors
*.gguf
.cache/

# Streamlit: ship only the offline config (telemetry disabled)
.streamlit/*
!.streamlit/config.toml

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/

# Video: linked on YouTube, kept out of the repo
*.mp4
*.mov

# Outputs: ship the json + png evidence; hide the working analysis
# (its content is folded into build-submission.md)
outputs/model_comparison.md

# Sensitive
.env
*.key

# Personal notes (not for submission)
myNotes.md
myNotes.md.*

# Internal dev docs (not shipping)
CLAUDE.md
LOG.md

# Prior work / internal (not shipping). Anchored to repo root so they do not match
# nested dirs like outputs/screenshots/.
/references/
/blog_notes/
/screenshots/
/notebooks/
/writeup/

# Prescriptions (raw originals - keep OUT of the repo)
data/prescriptions/*.jpg
data/prescriptions/*.jpeg
data/prescriptions/**/*.jpg
data/prescriptions/**/*.jpeg

# Redacted prescription set IS committable (PII removed/substituted + verified)
!data/prescriptions_redacted/
!data/prescriptions_redacted/*.jpeg

# Voice memos: hide raw/old; ship the 3 demo memos the app uses
data/voice_memos/*.wav
data/voice_memos/*.aiff
data/voice_memos/*.m4a
data/voice_memos/**/*.wav
data/voice_memos/**/*.aiff
data/voice_memos/**/*.m4a
!data/voice_memos/UC1_voicememo_us_english.wav
!data/voice_memos/UC3a_voicememo_indianenglish.wav
!data/voice_memos/UC3b_voicememo_telugu.wav
